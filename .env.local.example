# Rename this file to .env.local and fill in your Supabase project values.
# Find them in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Public site URL (used for SEO metadata / sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NOTE: For direct sign-up / login (no "confirm your email" step), turn OFF
# email confirmation in Supabase Dashboard → Authentication → Providers → Email
# → uncheck "Confirm email". This also stops the "email rate limit exceeded" errors.

# ---- OPTIONAL: email notifications for new inquiries (via Resend) ----
# Leave these blank to disable email — inquiries are still saved to the database.
# Get a free key at https://resend.com → API Keys
RESEND_API_KEY=
# Where new-inquiry emails are sent:
ADMIN_NOTIFICATION_EMAIL=
# Verified sender (use onboarding@resend.dev for testing, or your verified domain):
RESEND_FROM_EMAIL=onboarding@resend.dev
